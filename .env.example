PORT=5000
DATABASE_URL=your_database_url
JWT_SECRET=your_super_secret_key
JWT_EXPIRES=7d
CLIENT_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_URL=http://localhost:5173/reset-password
PASSWORD_RESET_EXPIRES_MINUTES=15

DB_SSL=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Email SMTP. Isi ini kalau ingin email benar-benar terkirim.
# Jika dikosongkan pada mode development, email akan dicetak ke console.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Bento-do <no-reply@bento-do.local>"
EMAIL_DEV_LOG=true

# Deadline reminder email dispatcher.
EMAIL_NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_INTERVAL_MS=60000
NOTIFICATION_EMAIL_BATCH_LIMIT=50
